---
import { business, nav } from '../data/business';
---

<header class="sticky top-0 z-40 border-b border-mist bg-paper/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="font-display text-xl tracking-tight ">{business.name}</a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a href={item.href} class="text-sm text-slate transition-colors hover:text-ink">
            {item.label}
          </a>
        ))
      }
      <a
        href={`/contact`}
        class="bg-ink px-4 py-2 text-sm text-paper transition-colors hover:bg-graphite rounded"
      >
        {"Get a Quote"}
      </a>
    </nav>
  </div>
</header>
